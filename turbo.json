{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": ["DEEPSEEK_API_KEY", "LLM_BASE_URL", "LLM_MODEL", "PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "*.tsbuildinfo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    }
  }
}
