{
  "name": "@parrot/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "test": "tsx --test src/domain/*.test.ts"
  },
  "dependencies": {
    "@diffusionstudio/piper-wasm": "^1.0.0",
    "express": "^5.2.1",
    "naudiodon-neo": "^2.4.1",
    "onnxruntime-node": "^1.26.0",
    "openai": "^6.42.0",
    "smart-whisper": "^0.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@parrot/eslint-config": "workspace:*",
    "@parrot/tsconfig": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/ws": "^8.18.1",
    "eslint": "catalog:",
    "tsx": "^4.22.4",
    "typescript": "catalog:"
  }
}
