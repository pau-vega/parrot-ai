# Parrot AI environment variables.
# Copy to `.env` (gitignored) and fill in. The backend loads this at startup
# and passes the values to the Python pipeline via process.env.

# Required. The Python pipeline fails to start without it.
DEEPSEEK_API_KEY=

# Optional. OpenAI-compatible LLM endpoint. Defaults to DeepSeek.
# LLM_BASE_URL=https://api.deepseek.com/v1

# Optional. LLM model name. Defaults to deepseek-chat (never the reasoner/R1).
# LLM_MODEL=deepseek-chat

# Optional. Node backend port. Defaults to 8000.
# PORT=8000
