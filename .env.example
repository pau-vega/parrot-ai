# Parrot AI environment variables.
# Copy to `.env` (gitignored) and fill in. The Python agent (apps/agent) auto-loads
# this repo-root file at startup via python-dotenv.

# Required. The LLM client raises on startup without it.
DEEPSEEK_API_KEY=

# Optional. OpenAI-compatible LLM endpoint. Defaults to DeepSeek.
# LLM_BASE_URL=https://api.deepseek.com/v1

# Optional. LLM model name. Defaults to deepseek-chat (never the reasoner/R1).
# LLM_MODEL=deepseek-chat

# Note: STT model (whisper base/int8), TTS voice (es_ES-davefx-medium), max tokens
# (160) and the server port (8000) are constants in apps/agent/app.py, not env vars.
