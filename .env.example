# Parrot AI environment variables.
# Copy to `.env` (gitignored) and fill in. The backend auto-loads this repo-root
# file at startup via Node's process.loadEnvFile() (no dotenv dependency).

# Required. The LLM client throws on startup without it.
DEEPSEEK_API_KEY=

# Optional. OpenAI-compatible LLM endpoint. Defaults to DeepSeek.
# LLM_BASE_URL=https://api.deepseek.com/v1

# Optional. LLM model name. Defaults to deepseek-chat (never the reasoner/R1).
# LLM_MODEL=deepseek-chat

# Optional. Max tokens per reply. Defaults to 160 (short voice replies).
# LLM_MAX_TOKENS=160

# Optional. whisper.cpp STT model. Defaults to base.
# WHISPER_MODEL=base

# Optional. Piper TTS voice. Defaults to es_ES-davefx-medium.
# PIPER_VOICE=es_ES-davefx-medium

# Optional. Node backend port. Defaults to 8000.
# PORT=8000
