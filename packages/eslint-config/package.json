{
  "name": "@parrot/eslint-config",
  "version": "1.0.0",
  "license": "ISC",
  "type": "module",
  "private": false,
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.9.0",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "catalog:",
    "typescript-eslint": "^8.61.1"
  },
  "devDependencies": {
    "@parrot/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
